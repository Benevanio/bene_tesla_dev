include ../mixins/cards.pug

section.projects#projects(data-section="projects")
  .container
    .section-title
      h2 Projetos Tecnicos
      p Projetos com foco em arquitetura, integracoes e engenharia de software.
    .projects-grid
      +projectCard({ type: 'Back-End', architecture: 'Clean Architecture', name: 'AuthKnex', description: 'Sistema de autenticacao com Node.js, TypeScript, JWT e estrategia de seguranca para APIs empresariais.', tech: ['Node.js', 'TypeScript', 'PostgreSQL', 'JWT'], link: 'https://github.com/Benevanio/AuthKnex' })
      +projectCard({ type: 'Back-End', architecture: 'MVC', name: 'RestSpring', description: 'API REST com Java e Spring Boot, documentacao OpenAPI e padroes para governanca de endpoints.', tech: ['Java', 'Spring Boot', 'JPA', 'OpenAPI'], link: 'https://github.com/Benevanio/RestSpring' })
      +projectCard({ type: 'Integracoes', architecture: 'API-Led', name: 'MuleSoft Integrations', description: 'Implementacao de fluxos MuleSoft com DataWeave e politicas para integracoes corporativas.', tech: ['MuleSoft', 'DataWeave', 'REST', 'SOAP'], link: 'https://github.com/Benevanio/api-specification' })
      +projectCard({ type: 'Full Stack', architecture: 'SPA + API', name: 'Social Media API', description: 'Aplicacao de estudo com back-end Node.js e front-end React, cobrindo autenticacao e modelagem social.', tech: ['Node.js', 'React', 'MongoDB', 'Express'], link: 'https://github.com/Benevanio/socialmedia' })
      +projectCard({ type: 'Back-End', architecture: 'Event-Driven', name: 'Async Product Pipeline', description: 'Sistema de processamento assincrono de produtos em batch com Node.js, ActiveMQ e MongoDB. Cron jobs para retry automatico — inspirado em fluxos de producao corporativos.', tech: ['Node.js', 'ActiveMQ', 'MongoDB', 'Cron'], link: 'https://github.com/Benevanio/Async-Product-Pipeline' })
      +projectCard({ type: 'Observabilidade', architecture: 'MVC', name: 'Node Monitoring', description: 'Sistema de monitoramento que transforma logs JSON do MongoDB/Joi em inteligencia de negocio no Kibana. Une precisao tecnica do Dev com tomada de decisao para PMs e POs.', tech: ['Node.js', 'MongoDB', 'Kibana', 'Joi'], link: 'https://github.com/Benevanio/node-monitoring' })
