doctype html
html(lang="pt-BR")
  head
    block head
      meta(charset="UTF-8")
      meta(name="viewport" content="width=device-width, initial-scale=1")
      meta(name="description" content="Portfolio profissional de Benevanio Santos, Engenheiro de Software")
      title Benevanio Santos | Engenheiro de Software
      script.
        (() => {
          try {
            const storedTheme = localStorage.getItem('theme')
            const systemPrefersDark = window.matchMedia
              ? window.matchMedia('(prefers-color-scheme: dark)').matches
              : false
            const theme = storedTheme || (systemPrefersDark ? 'dark' : 'light')
            document.documentElement.setAttribute('data-theme', theme)
          } catch (error) {
            document.documentElement.setAttribute('data-theme', 'light')
          }
        })()
      link(rel="preconnect" href="https://fonts.googleapis.com")
      link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
      link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Public+Sans:wght@400;500;600;700&display=swap" rel="stylesheet")
      link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
      link(rel="stylesheet" href="/stylesheets/style.css?v=8")
  body
    a.skip-link(href="#main-content") Ir para o conteudo principal
    .ambient-glow(data-ambient-glow aria-hidden="true")
    .tesla-overlay(data-tesla-overlay aria-hidden="true")
      .tesla-tribute
        img.tesla-portrait(src="https://upload.wikimedia.org/wikipedia/commons/7/79/Tesla_circa_1890.jpeg" alt="Retrato classico de Nikola Tesla")
        span.tesla-symbol(data-tesla-symbol) ⚡
    header.site-header
      .container
        nav.site-nav(aria-label="Principal")
          a.logo(href="#intro" aria-label="Inicio") BS
          button.theme-toggle(type="button" aria-label="Alternar tema" title="Alternar tema" data-theme-toggle)
            i.fas.fa-moon.theme-toggle__icon.theme-toggle__icon--moon(aria-hidden="true")
            i.fas.fa-sun.theme-toggle__icon.theme-toggle__icon--sun(aria-hidden="true")
          button.hamburger(type="button" aria-label="Abrir menu" aria-expanded="false" data-menu-toggle)
            span
            span
            span
          ul.nav-menu(data-menu)
            li
              a(href="#profile") Sobre
            li
              a(href="#results") Resultados
            li
              a(href="#career") Trajetoria
            li
              a(href="#principles") Arquitetura
            li
              a(href="#projects") Projetos
            li
              a(href="#contact") Contato
    main#main-content
      block content
    footer.site-footer
      .container
        .social-links
          a(href="https://linkedin.com/in/bene-tesla" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn")
            i.fab.fa-linkedin(aria-hidden="true")
          a(href="https://github.com/Benevanio" target="_blank" rel="noopener noreferrer" aria-label="GitHub")
            i.fab.fa-github(aria-hidden="true")
          a(href="mailto:benevaniosantos930@gmail.com" aria-label="E-mail")
            i.fas.fa-envelope(aria-hidden="true")
        p
          | © #{new Date().getFullYear()} Benevanio Santos. Engenharia de software orientada a resultados.
    block scripts
      script(src="/javascripts/main.js?v=8" defer)
