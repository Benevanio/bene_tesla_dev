doctype html
html(lang="pt-BR")
  head
    block head
      meta(charset="UTF-8")
      meta(name="viewport" content="width=device-width, initial-scale=1")
      meta(name="description" content="Portfolio profissional de Benevanio Santos, Engenheiro de Software")
      title Benevanio Santos | Engenheiro de Software
      link(rel="preconnect" href="https://fonts.googleapis.com")
      link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
      link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Public+Sans:wght@400;500;600;700&display=swap" rel="stylesheet")
      link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
      link(rel="stylesheet" href="/stylesheets/style.css?v=7")
  body
    a.skip-link(href="#main-content") Ir para o conteudo principal
    header.site-header
      .container
        nav.site-nav(aria-label="Principal")
          a.logo(href="#intro" aria-label="Inicio") BS
          button.hamburger(type="button" aria-label="Abrir menu" aria-expanded="false" data-menu-toggle)
            span
            span
            span
          ul.nav-menu(data-menu)
            li
              a(href="#profile") Sobre
            li
              a(href="#results") Resultados
            li
              a(href="#career") Trajetoria
            li
              a(href="#principles") Arquitetura
            li
              a(href="#projects") Projetos
            li
              a(href="#contact") Contato
    main#main-content
      block content
    footer.site-footer
      .container
        .social-links
          a(href="https://linkedin.com/in/bene-tesla" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn")
            i.fab.fa-linkedin(aria-hidden="true")
          a(href="https://github.com/Benevanio" target="_blank" rel="noopener noreferrer" aria-label="GitHub")
            i.fab.fa-github(aria-hidden="true")
          a(href="mailto:benevaniosantos930@gmail.com" aria-label="E-mail")
            i.fas.fa-envelope(aria-hidden="true")
        p
          | © #{new Date().getFullYear()} Benevanio Santos. Engenharia de software orientada a resultados.
    block scripts
      script(src="/javascripts/main.js?v=7" defer)
